            <div class="slide"><img src="./img/lancero777.png" alt="a"></div>
            <div class="slide"><img src="./img/lancero777.png" alt="a"></div>
        </div>
        <!-- Flechas para moverse por el carrusel -->
        <!-- Anterior -->
        <label for="slide1" class="flecha prev flecha_Prev2">&lt;</label>
        <label for="slide2" class="flecha prev flecha_Prev3">&lt;</label>
        <!-- Posterior -->
        <label for="slide2" class="flecha next flecha_Next1">&gt;</label>
        <label for="slide3" class="flecha next flecha_Next2">&gt;</label>
        <!-- Puntos de navegacion -->
        <div class="dots">
            <label class="dot" for="slide1"></label>
            <label class="dot" for="slide2"></label>
